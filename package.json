{
  "name": "oxf",
  "version": "0.1.0",
  "description": "High-performance local-first dictionary CLI built with Bun",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "bin": {
    "oxf": "./bin/oxf.ts"
  },
  "scripts": {
    "start": "bun run bin/oxf.ts",
    "link:global": "bun link",
    "unlink:global": "bun unlink",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.worktrees\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\" \"#.worktrees\"",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint && bun run lint:md && bun test",
    "pkg:check": "publint && npm pack --dry-run",
    "check:all": "bun run check && bun run pkg:check",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "prepare": "[ -d .git ] && husky || echo 'Skipping husky install (no .git directory)'",
    "typecheck": "bunx tsc --noEmit",
    "build:core": "bun run scripts/build-core.ts",
    "build:full": "bun run scripts/build-full.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "markdownlint-cli2": "^0.21.0",
    "publint": "^0.3.18",
    "wordnet-db": "^3.1.14"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
