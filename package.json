{
  "name": "@kitsunekode/oxf",
  "version": "0.3.0",
  "description": "High-performance local-first dictionary CLI built with Bun",
  "type": "module",
  "license": "MIT",
  "author": "kitsunekode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KitsuneKode/oxford-dictionary-cli.git"
  },
  "homepage": "https://github.com/KitsuneKode/oxford-dictionary-cli#readme",
  "bugs": {
    "url": "https://github.com/KitsuneKode/oxford-dictionary-cli/issues"
  },
  "keywords": [
    "bun",
    "cli",
    "dictionary",
    "language",
    "local-first",
    "offline",
    "wordnet"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/oxf",
    "dist/oxf.js",
    "completions",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "oxf": "bin/oxf"
  },
  "scripts": {
    "start": "bun run bin/oxf.ts",
    "build": "mkdir -p dist && bun build --minify --target bun --outfile dist/oxf.js bin/oxf.ts",
    "link:global": "bun run build && bun link",
    "unlink:global": "bun unlink",
    "relink:global": "bun unlink && bun run link:global",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.worktrees\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\" \"#.worktrees\"",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint && bun run lint:md && bun test",
    "pkg:check": "bun run build && publint && npm pack --dry-run --ignore-scripts",
    "check:all": "bun run check && bun run pkg:check",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "prepare": "[ -f .git/config ] && [ -w .git/config ] && husky || echo 'Skipping husky install (no writable .git config)'",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check && bun run build",
    "typecheck": "bunx tsc --noEmit",
    "build:core": "bun run scripts/build-core.ts",
    "build:full": "bun run scripts/build-full.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "markdownlint-cli2": "^0.21.0",
    "publint": "^0.3.18",
    "wordnet-db": "^3.1.14"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
